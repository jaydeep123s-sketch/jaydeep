# ---- AI model (Together AI) ----
# Get this key from https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here
# Exact DeepSeek model id from Together's model catalog
TOGETHER_MODEL=deepseek-ai/DeepSeek-V4-Pro

PORT=3000

# ---- Database (MongoDB Atlas — free tier) ----
# Create a free cluster at https://www.mongodb.com/cloud/atlas/register
# then copy the connection string here.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/opsmind?retryWrites=true&w=majority

# ---- Auth ----
# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# ---- Free plan limit ----
FREE_MESSAGE_LIMIT=20

# ---- Payments (PhonePe) ----
# Get these from the PhonePe Business Dashboard: https://business.phonepe.com
PHONEPE_MERCHANT_ID=your_merchant_id
PHONEPE_SALT_KEY=your_salt_key
PHONEPE_SALT_INDEX=1
# SANDBOX while testing, PRODUCTION once PhonePe approves your live account
PHONEPE_ENV=SANDBOX
# Price of the Pro (unlimited) plan, in paise. 19900 = ₹199.00
PRO_PRICE_PAISE=19900

# Public URL of your deployed app (used for PhonePe redirect/callback URLs).
# Locally this is http://localhost:3000. On Railway it's your generated *.up.railway.app domain.
APP_BASE_URL=http://localhost:3000

# ---- Related videos (optional — Perplexity-style YouTube suggestions) ----
# Free tier: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# If left blank, the app just links to a YouTube search instead of showing real results.
YOUTUBE_API_KEY=
